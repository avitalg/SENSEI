{
  "name": "sensei",
  "private": true,
  "version": "1.49.0",
  "description": "Sensei — Hebrew RTL therapist practice-management app. Production React port of the 'Sensei design 2026' prototype spec (v2.2.0).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_API_BASE_URL= vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test:coverage": "vitest run --coverage",
    "dup": "jscpd",
    "check": "npm run lint && npm run test && npm run build",
    "package": "git archive --format=zip -o sensei-app-2026.zip HEAD"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jscpd": "^4.2.5",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
