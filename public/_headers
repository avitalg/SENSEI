# Hashed, content-versioned build assets — safe to cache forever (immutable).
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Everything else (HTML entry + SPA routes) must always revalidate, so a returning
# user gets fresh HTML that references the current asset hashes (no stale UI).
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cache-Control: public, max-age=0, must-revalidate
